---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Placeholder: New Website"
  description="Simple placeholder landing page to collect leads and showcase your offering."
  ogTitle="Placeholder: New Website"
  ogDescription="Simple landing page to collect leads and showcase your offering."
>
  <main>
    <section class="section hero" role="region" aria-labelledby="heroHeading">
      <div class="container hero-grid">
        <div>
          <h1 id="heroHeading">We help busy teams launch faster.</h1>
          <p class="lead">Simple landing page to collect leads and showcase your offering.</p>
          <a href="#contact" class="btn">Get started</a>
        </div>
        <div class="media-placeholder" role="img" aria-label="Image or video placeholder">
          Image/Video Placeholder
        </div>
      </div>
    </section>

    <section class="section" id="about" role="region" aria-labelledby="aboutHeading">
      <div class="container">
        <h2 id="aboutHeading">About</h2>
        <p>
          We build simple, effective landing pages for startups and small businesses.
          We focus on clear messaging, clean design, and fast launch timelines.
        </p>
        <div class="logo-row" aria-label="Partner logo placeholders">
          <div class="logo-placeholder">Logo A</div>
          <div class="logo-placeholder">Logo B</div>
        </div>
      </div>
    </section>

    <section class="section" id="services" role="region" aria-labelledby="servicesHeading">
      <div class="container">
        <h2 id="servicesHeading">Services</h2>
        <ul class="service-list">
          <li><strong>Landing Pages</strong> - Fast, focused pages to collect leads.</li>
          <li><strong>Content Setup</strong> - Clear copy structure to explain your offer quickly.</li>
          <li><strong>Launch Support</strong> - Lightweight setup and handoff so you can go live confidently.</li>
        </ul>
      </div>
    </section>

    <section class="section" id="contact" role="region" aria-labelledby="contactHeading">
      <div class="container">
        <h2 id="contactHeading">Contact CTA</h2>
        <p class="contact-prompt">Ready to get started? Send us a message.</p>

        <form id="contactForm" method="post" action="/__forms/contact" novalidate>
          <div class="form-row">
            <label for="name">Name <span aria-label="required">*</span></label>
            <div>
              <input type="text" id="name" name="name" required aria-required="true" aria-describedby="nameError" />
              <span id="nameError" class="error-message"></span>
            </div>
          </div>

          <div class="form-row">
            <label for="email">Email <span aria-label="required">*</span></label>
            <div>
              <input type="email" id="email" name="email" required aria-required="true" aria-describedby="emailError" />
              <span id="emailError" class="error-message"></span>
            </div>
          </div>

          <div class="form-row">
            <label for="message">Message <span aria-label="required">*</span></label>
            <div>
              <textarea id="message" name="message" rows="5" required aria-required="true" aria-describedby="messageError"></textarea>
              <span id="messageError" class="error-message"></span>
            </div>
          </div>

          <input type="hidden" name="recipient" value="sonnywebsites@gmail.com" />
          <input type="hidden" name="to" value="sonnywebsites@gmail.com" />
          <input type="text" name="_hp" class="hp-field" autocomplete="off" tabindex="-1" />

          <button type="submit" id="submitBtn" class="btn" aria-busy="false">Submit</button>
        </form>

        <div id="responseMessage" role="alert" aria-live="polite"></div>
      </div>
    </section>
  </main>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
---

<BaseLayout
  title="blahblah"
  description="Thanks for your message."
  ogTitle="blahblah"
  ogDescription="Thanks for your message."
>
  <main>
    <section class="section" role="main" aria-labelledby="thankHeading">
      <div class="container">
        <h1 id="thankHeading">Thank you</h1>
        <p>Your message has been sent. We will follow up soon.</p>
        <a class="btn" href={base + '/'}>Back to home</a>
      </div>
    </section>
  </main>
</BaseLayout>
